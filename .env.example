# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
# URL pública del servidor (se usa para generar el QR de unión a la sala)
# BASE_URL=http://localhost:3000
# Si se omite, se auto-detecta la IP local (ej: http://192.168.1.x:3000)

# ─── Quiz ────────────────────────────────────────────────────────────────────
# Segundos por pregunta (por defecto: 25)
QUESTION_TIME_LIMIT=21
# Segundos que se muestra la pantalla de respuesta correcta antes de pasar a la siguiente (por defecto: 8)
RESULTS_DELAY=8
# Cuántas preguntas por partida (subconjunto aleatorio del banco); omitir = todas las del banco
QUESTION_COUNT=21
# Categorías de preguntas a usar (separadas por coma). Por defecto: bitcoin (principiantes)
# Categorías disponibles: bitcoin, blockchain, mining, lightning, wallets,
#                         transactions, channels, lsp, dev
# Ejemplos:
#   CATEGORIES=bitcoin                        → solo preguntas generales
#   CATEGORIES=lightning,channels,lsp         → evento temático Lightning
#   CATEGORIES=bitcoin,blockchain,mining      → evento temático técnico
CATEGORIES=bitcoin

# ─── Recompensa Lightning ─────────────────────────────────────────────────────
# Sats que se otorgan al ganador por cada punto (puntuación máx ~2500 sats por quiz)
SAT_PER_POINT=1

# ══════════════════════════════════════════════════════════════════════════════
#  OPCIÓN 1 — NWC  (Nostr Wallet Connect) — MÁS FÁCIL ✅
#  Compatible con: Alby, Zeus, Bitkit y cualquier wallet NWC
#  Obtén tu cadena de conexión en: https://nwc.getalby.com
# ══════════════════════════════════════════════════════════════════════════════
NWC_URL=
# Example: NWC_URL=nostr+walletconnect://your-connection-string-here

# ══════════════════════════════════════════════════════════════════════════════
#  OPCIÓN 2 — LND REST  (para quienes corren su propio nodo) — AVANZADO
# ══════════════════════════════════════════════════════════════════════════════
LND_REST_URL=
LND_MACAROON=
# Example: LND_REST_URL=https://your-lnd-node:8080
# Example: LND_MACAROON=your-macaroon-in-hex
# Certificado TLS de LND en base64 (opcional; si se omite se desactiva verificación TLS)
LND_CERT=

# ─── Nota ────────────────────────────────────────────────────────────────────
# Si ninguna opción está configurada, el servidor corre en modo manual:
# muestra el monto en sats para que el presentador pague desde su wallet.
